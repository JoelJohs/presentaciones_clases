---
import type { NavigationResult } from '../utils/navigation';

interface Props {
  nav: NavigationResult;
}

const { nav } = Astro.props;

function moduleNumber(title: string): number {
  const match = title.match(/^(\d+)/);
  return match ? parseInt(match[1], 10) : 0;
}

const processedModules = nav.modules.map(mod => ({
  title: mod.title,
  badge: moduleNumber(mod.title),
  lessons: mod.topics.flatMap(t => t.lessons).map(l => ({
    slug: l.slug,
    title: l.title,
    isRepaso: l.slug.endsWith('/repaso'),
  })),
}));

const processedExtras = nav.extras
  .filter(mod => mod.title.charAt(0) !== 'P')
  .map(mod => ({
    title: mod.title,
    badge: mod.title.charAt(0),
    lessons: mod.topics.flatMap(t => t.lessons).map(l => ({
      slug: l.slug,
      title: l.title,
      isRepaso: l.slug.endsWith('/repaso'),
    })),
  }));

const allLessonsData = processedModules.flatMap(m =>
  m.lessons.map(l => ({ slug: l.slug, title: l.title }))
);
const dashboardData = JSON.stringify({ modules: processedModules, extras: processedExtras, lessons: allLessonsData });
---

<div id="dashboard-data" class="hidden">{dashboardData}</div>

<div x-data="dashboard" class="space-y-4">
  <!-- Instrucción -->
  <p class="text-xs text-brand-muted leading-relaxed">
    Completa las lecciones en orden. Tu progreso se guarda automáticamente en este dispositivo.
  </p>

  <!-- Barra de progreso -->
  <div class="rounded-xl border border-brand-border bg-white dark:bg-brand-sidebar-bg p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-semibold text-brand-navy dark:text-white">
        <span x-text="completedCount"></span> de <span x-text="totalCount"></span> lecciones
      </span>
      <span class="text-sm font-bold text-brand-primary" x-text="percent + '%'"></span>
    </div>
    <div class="h-2 rounded-full bg-brand-border overflow-hidden">
      <div class="h-full rounded-full bg-brand-primary transition-all duration-500" :style="'width:' + percent + '%'"></div>
    </div>
  </div>

  <!-- Continuar -->
  <template x-if="nextLesson">
    <a :href="'/' + nextLesson.slug"
       class="flex items-center justify-between gap-4 rounded-xl border border-brand-primary/40 bg-brand-callout-bg dark:bg-brand-hover-bg p-5 hover:border-brand-primary hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-200 group min-h-[72px]">
      <div class="min-w-0">
        <span class="text-xs font-semibold uppercase tracking-wider text-brand-primary flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
          Continuar
        </span>
        <p class="text-sm font-semibold text-brand-navy dark:text-white mt-1 truncate" x-text="nextLesson.title"></p>
      </div>
      <svg class="h-5 w-5 shrink-0 text-brand-primary transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </template>

  <!-- Todo completado -->
  <template x-if="!nextLesson && totalCount > 0">
    <div class="rounded-xl border border-brand-border bg-white dark:bg-brand-sidebar-bg p-5 text-center">
      <p class="text-lg font-bold text-brand-primary">¡Completaste todas las lecciones!</p>
      <p class="text-sm text-brand-muted mt-1">Vuelve pronto para más contenido.</p>
    </div>
  </template>

  <!-- Módulos curriculares -->
  <div class="space-y-2">
    <template x-for="(mod, i) in modules" :key="mod.title">
      <details class="group rounded-xl border border-brand-border bg-white dark:bg-brand-sidebar-bg overflow-hidden" :open="modDone(mod) < modTotal(mod)">
        <summary class="list-none flex items-center gap-3 p-4 cursor-pointer select-none hover:bg-brand-hover-bg/50 transition-colors">
          <span class="module-badge shrink-0" :class="'module-badge-m' + Math.min(i + 1, 7)" x-text="mod.badge"></span>
          <span class="flex-1 text-sm font-semibold text-brand-navy dark:text-white truncate" x-text="mod.title"></span>
          <span class="text-xs font-mono font-medium shrink-0" :class="modAllDone(mod) ? 'text-brand-primary' : 'text-brand-muted'" x-text="modDone(mod) + '/' + modTotal(mod)"></span>
          <svg class="h-4 w-4 shrink-0 text-brand-muted transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="border-t border-brand-border divide-y divide-brand-border">
          <template x-for="lesson in mod.lessons" :key="lesson.slug">
            <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-brand-hover-bg/30 transition-colors">
              <input type="checkbox"
                     :checked="done(lesson.slug)"
                     @change="toggle(lesson.slug)"
                     class="h-5 w-5 shrink-0 rounded border-brand-border text-brand-primary focus:ring-brand-primary cursor-pointer dark:bg-brand-sidebar-bg dark:checked:bg-brand-primary">
              <a :href="'/' + lesson.slug"
                 class="flex-1 text-sm min-w-0"
                 :class="done(lesson.slug) ? 'line-through opacity-60 text-brand-muted' : 'text-brand-text hover:text-brand-primary'">
                <template x-if="lesson.isRepaso">
                  <span class="text-brand-amber font-medium">Repaso: </span>
                </template>
                <span x-text="lesson.title"></span>
              </a>
              <a :href="'/' + lesson.slug" class="shrink-0 text-brand-muted hover:text-brand-primary transition-colors p-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                </svg>
              </a>
            </div>
          </template>
          <!-- Módulo completado -->
          <template x-if="modDone(mod) === modTotal(mod) && modTotal(mod) > 0">
            <div class="px-4 py-3 text-center">
              <span class="text-xs font-semibold text-brand-primary">✓ Módulo completado</span>
            </div>
          </template>
        </div>
      </details>
    </template>
  </div>

  <!-- Plan de Estudio -->
  <a href="/00-inicio/03-plan-de-estudio" class="flex items-center justify-between rounded-xl border border-brand-border bg-white dark:bg-brand-sidebar-bg px-4 py-3 hover:border-brand-primary transition-colors group">
    <div class="flex items-center gap-3">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-primary/10 text-brand-primary font-bold text-xs">📋</span>
      <div>
        <p class="text-sm font-semibold text-brand-navy dark:text-white group-hover:text-brand-primary transition-colors">Plan de Estudio</p>
        <p class="text-xs text-brand-muted">Temario, fechas y evaluación</p>
      </div>
    </div>
    <svg class="h-4 w-4 shrink-0 text-brand-muted transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </a>
</div>

<script>
  import Alpine from 'alpinejs';

  Alpine.data('dashboard', () => ({
    completed: [],
    modules: [],
    extras: [],
    lessons: [],
    percent: 0,
    completedCount: 0,
    totalCount: 0,
    nextLesson: null,

    init() {
      var data = JSON.parse(document.getElementById('dashboard-data').textContent);
      this.modules = data.modules;
      this.extras = data.extras;
      this.lessons = data.lessons;
      this.totalCount = this.lessons.length;
      this.load();
      this.recalc();
    },

    load() {
      try {
        var raw = localStorage.getItem('progress_completed');
        this.completed = raw ? JSON.parse(raw) : [];
      } catch (e) {
        this.completed = [];
      }
    },

    save() {
      localStorage.setItem('progress_completed', JSON.stringify(this.completed));
    },

    done(slug) {
      return this.completed.indexOf(slug) !== -1;
    },

    toggle(slug) {
      var idx = this.completed.indexOf(slug);
      if (idx === -1) {
        this.completed = this.completed.concat([slug]);
      } else {
        var arr = [];
        for (var i = 0; i < this.completed.length; i++) {
          if (this.completed[i] !== slug) arr.push(this.completed[i]);
        }
        this.completed = arr;
      }
      this.save();
      this.recalc();
    },

    recalc() {
      var done = 0;
      for (var i = 0; i < this.lessons.length; i++) {
        if (this.done(this.lessons[i].slug)) done++;
      }
      this.completedCount = done;
      this.percent = this.totalCount > 0 ? Math.round(done / this.totalCount * 100) : 0;
      this.nextLesson = null;
      for (var j = 0; j < this.lessons.length; j++) {
        if (!this.done(this.lessons[j].slug)) {
          this.nextLesson = this.lessons[j];
          break;
        }
      }
    },

    modDone(mod) {
      var count = 0;
      for (var i = 0; i < mod.lessons.length; i++) {
        if (this.done(mod.lessons[i].slug)) count++;
      }
      return count;
    },

    modTotal(mod) {
      return mod.lessons.length;
    },

    modAllDone(mod) {
      return this.modDone(mod) === this.modTotal(mod);
    },
  }));

  Alpine.start();
</script>
