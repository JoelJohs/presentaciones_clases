---
import type { NavigationResult } from '../utils/navigation';

interface Props {
  nav: NavigationResult;
  activeSlug: string;
}

const { nav, activeSlug } = Astro.props;
---

<aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-80 -translate-x-full border-r border-brand-border bg-brand-sidebar-bg p-6 transition-transform duration-300 lg:translate-x-0 overflow-y-auto">
  <div class="mb-8 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight text-brand-primary hover:text-brand-accent focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary rounded">
      Plataforma de Estudios
    </a>
  </div>

  <nav class="space-y-6">
    <!-- Initial Pages -->
    <ul class="space-y-2">
      {nav.initialPages.map((page) => (
        <li>
          <a
            href={`/${page.slug}`}
            class={`block rounded-md px-3 py-2 text-sm font-medium transition-colors focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary ${
              activeSlug === page.slug
                ? 'bg-brand-callout-bg text-brand-primary border-l-2 border-brand-primary'
                : 'text-slate-600 hover:bg-brand-hover-bg hover:text-brand-primary dark:text-slate-400 border-l-2 border-transparent'
            }`}
          >
            {page.title}
          </a>
        </li>
      ))}
    </ul>

    <!-- Modules -->
    {nav.modules.map((mod) => {
      const isModuleActive = mod.topics.some((topic) =>
        topic.lessons.some((lesson) => lesson.slug === activeSlug)
      );
      return (
        <details class="group space-y-2" open={isModuleActive}>
          <summary class="list-none cursor-pointer flex items-center justify-between text-xs font-semibold uppercase tracking-wider text-brand-muted hover:text-brand-primary select-none">
            <span>{mod.title}</span>
            <svg class="h-4 w-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          
          {mod.topics.map((topic) => {
            const isTopicActive = topic.lessons.some((lesson) => lesson.slug === activeSlug);
            return (
              <details class="group space-y-1" open={isTopicActive}>
                <summary class="list-none cursor-pointer flex items-center justify-between px-3 text-xs font-medium text-brand-muted hover:text-brand-primary select-none">
                  <span>{topic.title}</span>
                  <svg class="h-4 w-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <ul class="space-y-1 pl-3">
                  {topic.lessons.map((lesson) => {
                    const isRepaso = lesson.slug.endsWith('/repaso');
                    const displayTitle = isRepaso ? '↳ Repaso' : lesson.title;
                    return (
                      <li class={isRepaso ? 'pl-4' : ''}>
                        <a
                          href={`/${lesson.slug}`}
                          class={`block rounded-md px-3 py-1.5 text-xs font-medium transition-colors focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary ${
                            activeSlug === lesson.slug
                              ? 'bg-brand-callout-bg text-brand-primary border-l-2 border-brand-primary'
                              : 'text-slate-600 hover:bg-brand-hover-bg hover:text-brand-primary dark:text-slate-400 border-l-2 border-transparent'
                          }`}
                        >
                          {displayTitle}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </details>
            );
          })}
        </details>
      );
    })}
  </nav>
</aside>

<style>
  /* Ocultar flechas nativas de <summary> */
  summary::-webkit-details-marker {
    display: none;
  }
  summary {
    list-style: none;
  }
  details[open] > summary > svg {
    transform: rotate(180deg);
  }
</style>

