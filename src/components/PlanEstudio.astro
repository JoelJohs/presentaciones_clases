---
interface Subtema {
  nombre: string;
  descripcion: string;
  duracion: number;
}

interface Tema {
  titulo: string;
  subtemas: Subtema[];
}

interface Modulo {
  numero: number;
  titulo: string;
  color: string;
  semanas: number;
  progreso: number;
  temas: Tema[];
}

interface Props {
  modulos: Modulo[];
}

const { modulos } = Astro.props;

const totalSemanas = modulos.reduce(
  (sum, mod) => sum + mod.temas.reduce((s, t) => s + t.subtemas.length, 0),
  0,
);
---

<div id="plan-estudio">
  <div class="plan-global" id="plan-global">
    <div class="plan-global-row">
      <span class="plan-global-label">Progreso general</span>
      <span class="plan-global-count" id="plan-global-count">0/{totalSemanas}</span>
    </div>
    <div class="plan-global-bar">
      <div class="plan-global-fill" id="plan-global-fill" style="width:0%"></div>
    </div>
  </div>

  {
    modulos.map((mod) => (
      <div
        class="plan-modulo"
        style={`--c: ${mod.color}`}
        data-mod={mod.numero}
      >
        <div
          class="plan-row"
          role="button"
          tabindex="0"
          aria-expanded="false"
        >
          <span class="plan-num">{String(mod.numero).padStart(2, '0')}</span>
          <span class="plan-title">{mod.titulo}</span>
          <span class="plan-weeks" id={`plan-w-${mod.numero}`}>0/{mod.semanas}</span>
          <div class="plan-progress-wrap">
            <div class="plan-progress" id={`plan-p-${mod.numero}`} style="width:0%"></div>
          </div>
          <svg class="plan-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>

        <div class="plan-body hidden">
          <div class="plan-body-inner">
            {
              mod.temas.map((tema, ti) => (
                <div class="plan-tema">
                  <h3 class="plan-tema-title">
                    <span class="plan-dot" style={`background:${mod.color}`}></span>
                    {tema.titulo}
                  </h3>
                  <div class="plan-subtemas">
                    {tema.subtemas.map((st, si) => {
                      const id = `m${mod.numero}-${ti + 1}-${si + 1}`;
                      return (
                        <div class="plan-subtema">
                          <input type="checkbox" id={id} class="plan-cb" />
                          <label for={id} class="plan-st-name">{st.nombre}</label>
                          <span class="plan-st-desc">{st.descripcion}</span>
                          <span class="plan-st-dur">{st.duracion} sem</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    ))
  }
</div>

<script>
  (function () {
    var STORAGE_KEY = 'plan-estudio-progress';
    var wrapper = document.getElementById('plan-estudio');
    if (!wrapper) return;

    function allCbs() {
      return wrapper.querySelectorAll('.plan-cb');
    }

    function update() {
      var total = allCbs().length;
      if (total === 0) return;
      var checked = wrapper.querySelectorAll('.plan-cb:checked').length;
      var pct = Math.round(checked / total * 100);

      var globalCount = document.getElementById('plan-global-count');
      var globalFill = document.getElementById('plan-global-fill');
      if (globalCount) globalCount.textContent = checked + '/' + total;
      if (globalFill) globalFill.style.width = pct + '%';

      var mods = wrapper.querySelectorAll('.plan-modulo');
      for (var i = 0; i < mods.length; i++) {
        var mod = mods[i];
        var num = mod.getAttribute('data-mod');
        var cbs = mod.querySelectorAll('.plan-cb');
        var checkedMod = mod.querySelectorAll('.plan-cb:checked').length;
        var totalMod = cbs.length;
        var pctMod = totalMod > 0 ? Math.round(checkedMod / totalMod * 100) : 0;

        var wEl = document.getElementById('plan-w-' + num);
        var pEl = document.getElementById('plan-p-' + num);
        if (wEl) wEl.textContent = checkedMod + '/' + totalMod;
        if (pEl) pEl.style.width = pctMod + '%';
      }
    }

    function save() {
      var state = {};
      var cbs = allCbs();
      for (var i = 0; i < cbs.length; i++) {
        state[cbs[i].id] = cbs[i].checked;
      }
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
    }

    function load() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        var state = JSON.parse(raw);
        if (!state) return;
        var cbs = allCbs();
        for (var i = 0; i < cbs.length; i++) {
          if (state[cbs[i].id] === true) cbs[i].checked = true;
        }
      } catch (e) {}
    }

    wrapper.addEventListener('change', function (e) {
      if (e.target && e.target.classList.contains('plan-cb')) {
        save();
        update();
      }
    });

    wrapper.addEventListener('click', function (e) {
      var row = e.target.closest('.plan-row');
      if (!row) return;
      if (e.target.closest('.plan-cb, label')) return;
      var modulo = row.closest('.plan-modulo');
      if (!modulo) return;
      var isOpen = row.getAttribute('aria-expanded') === 'true';
      var body = modulo.querySelector('.plan-body');
      var chevron = row.querySelector('.plan-chevron');

      wrapper.querySelectorAll('.plan-row[aria-expanded="true"]').forEach(function (r) {
        if (r !== row) {
          r.setAttribute('aria-expanded', 'false');
          var b = r.closest('.plan-modulo')?.querySelector('.plan-body');
          if (b) b.classList.add('hidden');
          var ch = r.closest('.plan-modulo')?.querySelector('.plan-chevron');
          if (ch) ch.classList.remove('open');
        }
      });

      if (isOpen) {
        row.setAttribute('aria-expanded', 'false');
        body?.classList.add('hidden');
        chevron?.classList.remove('open');
      } else {
        row.setAttribute('aria-expanded', 'true');
        body?.classList.remove('hidden');
        chevron?.classList.add('open');
      }
    });

    wrapper.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      var row = e.target.closest('.plan-row');
      if (row) { e.preventDefault(); row.click(); }
    });

    load();
    update();
  })();
</script>

<style>
  #plan-estudio {
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
  }

  .plan-global {
    padding: 12px 0 16px;
    margin-bottom: 4px;
    border-bottom: 2px solid var(--color-brand-border);
  }

  .plan-global-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .plan-global-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-brand-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .plan-global-count {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-brand-primary);
  }

  .plan-global-bar {
    height: 6px;
    background: var(--color-brand-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .plan-global-fill {
    height: 100%;
    background: var(--color-brand-primary);
    border-radius: 3px;
    transition: width 0.3s;
  }

  .plan-modulo {
    border-bottom: 1px solid var(--color-brand-border);
  }

  .plan-modulo:first-child {
    border-top: 1px solid var(--color-brand-border);
  }

  .plan-row {
    display: grid;
    grid-template-columns: 40px 1fr auto 80px 24px;
    align-items: center;
    gap: 12px;
    padding: 12px 8px 12px 0;
    cursor: pointer;
    user-select: none;
    transition: background-color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .plan-row:hover {
      background: var(--color-brand-hover-bg);
    }
  }

  .plan-row:focus-visible {
    outline: 2px solid var(--color-brand-primary);
    outline-offset: -2px;
  }

  .plan-num {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 14px;
    font-weight: 700;
    color: var(--c);
    text-align: right;
    line-height: 1;
  }

  .plan-title {
    font-family: var(--font-display, 'Outfit', sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-brand-text);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .plan-weeks {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 12px;
    color: var(--color-brand-muted);
    white-space: nowrap;
    text-align: right;
  }

  .plan-progress-wrap {
    height: 4px;
    background: var(--color-brand-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .plan-progress {
    height: 100%;
    background: var(--c);
    border-radius: 2px;
    transition: width 0.3s;
  }

  .plan-chevron {
    width: 14px;
    height: 14px;
    color: var(--color-brand-muted);
    transition: transform 0.2s;
    justify-self: center;
  }

  .plan-chevron.open {
    transform: rotate(90deg);
  }

  .plan-body {
    border-top: 1px solid var(--color-brand-border);
  }

  .plan-body-inner {
    padding: 0 0 16px 52px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .plan-tema-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 8px 0;
    padding: 0;
    border: 0;
  }

  .plan-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .plan-subtemas {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .plan-subtema {
    display: grid;
    grid-template-columns: auto 160px 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 3px 0;
  }

  .plan-cb {
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--color-brand-border);
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    align-self: center;
    margin: 0;
    transition: border-color 0.15s, background 0.15s;
  }

  .plan-cb:hover {
    border-color: var(--c, var(--color-brand-primary));
  }

  .plan-cb:checked {
    background: var(--c, var(--color-brand-primary));
    border-color: var(--c, var(--color-brand-primary));
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='white' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12.207 4.793a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0l-2-2a1 1 0 011.414-1.414L6.5 9.086l4.293-4.293a1 1 0 011.414 0z'/%3E%3C/svg%3E");
    background-size: 12px;
    background-position: center;
    background-repeat: no-repeat;
  }

  .plan-cb:focus-visible {
    outline: 2px solid var(--color-brand-primary);
    outline-offset: 1px;
  }

  .plan-st-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-brand-text);
    line-height: 1.4;
    cursor: pointer;
  }

  .plan-cb:checked + .plan-st-name {
    text-decoration: line-through;
    text-decoration-color: var(--color-brand-muted);
    opacity: 0.6;
  }

  .plan-st-desc {
    font-size: 13px;
    color: var(--color-brand-muted);
    line-height: 1.4;
    min-width: 0;
  }

  .plan-st-dur {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 11px;
    color: var(--color-brand-muted);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .plan-row {
      grid-template-columns: 32px 1fr auto 20px;
      gap: 8px;
      padding: 10px 0;
    }

    .plan-progress-wrap {
      display: none;
    }

    .plan-title {
      font-size: 13px;
    }

    .plan-num {
      font-size: 12px;
    }

    .plan-body-inner {
      padding: 0 0 12px 36px;
      gap: 12px;
    }

    .plan-subtema {
      grid-template-columns: auto 1fr auto;
      gap: 6px;
    }

    .plan-st-desc {
      display: none;
    }

    .plan-st-name {
      font-size: 13px;
    }
  }
</style>
