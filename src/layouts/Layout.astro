---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.astro';
import type { NavigationResult } from '../utils/navigation';

interface Props {
  title?: string;
  nav?: NavigationResult;
  activeSlug?: string;
}

const { 
  title = 'Plataforma de Estudios', 
  nav = { initialPages: [], modules: [], extras: [], allLessonsOrdered: [] }, 
  activeSlug = '' 
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Plataforma de lecciones y material de clases de tecnología e informática." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Plataforma de Estudios</title>

    <!-- Dark Mode & Layout Settings Initial Script to Prevent Flashing -->
    <script is:inline>
      if (
        localStorage.getItem('color-theme') === 'dark' ||
        (!('color-theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      if (localStorage.getItem('sidebar-collapsed') === 'true') {
        document.documentElement.classList.add('sidebar-collapsed');
      }

      const viewMode = localStorage.getItem('view-mode') || 'reading';
      document.documentElement.classList.add(`${viewMode}-mode`);
    </script>
  </head>
  <body class="bg-brand-bg text-brand-text antialiased">
    <div class="min-h-screen">
      <!-- Backdrop for mobile sidebar -->
      <div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-black/30 backdrop-blur-sm transition-all duration-300 opacity-0 pointer-events-none lg:hidden"></div>

      <!-- Sidebar -->
      <Sidebar nav={nav} activeSlug={activeSlug} />

      <!-- Main Panel -->
      <div id="main-content-wrapper" class="lg:pl-72 flex flex-col min-h-screen transition-all duration-300">
        <Header />

        <main class="flex-1 px-5 sm:px-8 py-10 max-w-3xl mx-auto w-full page-enter">
          <slot />
        </main>
      </div>
    </div>

    <!-- Scripts: Sidebar, Theme, Mode -->
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');

      function toggleMobileSidebar(open) {
        if (!sidebar || !backdrop) return;
        if (open) {
          sidebar.classList.remove('-translate-x-full');
          backdrop.classList.remove('opacity-0', 'pointer-events-none');
          backdrop.classList.add('opacity-100');
          document.body.style.overflow = 'hidden';
        } else {
          sidebar.classList.add('-translate-x-full');
          backdrop.classList.add('opacity-0', 'pointer-events-none');
          backdrop.classList.remove('opacity-100');
          document.body.style.overflow = '';
        }
      }

      if (menuToggle && sidebar) {
        menuToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !sidebar.classList.contains('-translate-x-full');
          toggleMobileSidebar(!isOpen);
        });

        backdrop?.addEventListener('click', () => toggleMobileSidebar(false));

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && sidebar && !sidebar.classList.contains('-translate-x-full')) {
            toggleMobileSidebar(false);
          }
        });
      }

      const themeToggle = document.getElementById('theme-toggle');
      const lightIcon = document.getElementById('theme-toggle-light-icon');
      const darkIcon = document.getElementById('theme-toggle-dark-icon');

      function updateIcons() {
        if (!lightIcon || !darkIcon) return;
        if (document.documentElement.classList.contains('dark')) {
          lightIcon.classList.remove('hidden');
          darkIcon.classList.add('hidden');
        } else {
          lightIcon.classList.add('hidden');
          darkIcon.classList.remove('hidden');
        }
      }
      updateIcons();

      themeToggle?.addEventListener('click', () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('color-theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('color-theme', 'dark');
        }
        updateIcons();
      });

      const sidebarToggle = document.getElementById('sidebar-toggle');
      sidebarToggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('sidebar-collapsed');
        localStorage.setItem('sidebar-collapsed', String(document.documentElement.classList.contains('sidebar-collapsed')));
      });

      const btnReading = document.getElementById('btn-reading-mode');
      const btnPresentation = document.getElementById('btn-presentation-mode');

      function updateModeUI(mode) {
        const isPres = mode === 'presentation';
        document.documentElement.classList.toggle('presentation-mode', isPres);
        document.documentElement.classList.toggle('reading-mode', !isPres);

        btnReading?.classList.toggle('mode-btn-active', !isPres);
        btnPresentation?.classList.toggle('mode-btn-active', isPres);

        if (isPres) {
          btnReading?.classList.remove('text-brand-muted');
          btnPresentation?.classList.remove('text-brand-muted');
        } else {
          btnPresentation?.classList.add('text-brand-muted');
          btnReading?.classList.add('text-brand-muted');
        }
      }

      const currentMode = document.documentElement.classList.contains('presentation-mode') ? 'presentation' : 'reading';
      updateModeUI(currentMode);

      btnReading?.addEventListener('click', () => {
        localStorage.setItem('view-mode', 'reading');
        updateModeUI('reading');
      });

      btnPresentation?.addEventListener('click', () => {
        localStorage.setItem('view-mode', 'presentation');
        updateModeUI('presentation');
      });
    </script>

    <style is:global>
      @media (min-width: 1024px) {
        .sidebar-collapsed #sidebar {
          transform: translateX(-100%);
        }
        .sidebar-collapsed #main-content-wrapper {
          padding-left: 0 !important;
        }
      }
    </style>
  </body>
</html>
