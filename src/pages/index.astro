---
import { getCollection } from 'astro:content';
import { getNavigationStructure } from '../utils/navigation';
import Layout from '../layouts/Layout.astro';

const lecciones = await getCollection('lecciones');
const nav = getNavigationStructure(lecciones);
const firstLesson = nav.allLessonsOrdered.length > 0 ? nav.allLessonsOrdered[0] : null;
const allGroups = [...nav.modules, ...nav.extras];
---

<Layout title="Inicio">
  <div class="max-w-4xl mx-auto">
    <!-- Header compacto -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 pb-6 border-b border-brand-border">
      <div>
        <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-navy dark:text-white tracking-tight">
          Plataforma de Estudios
        </h1>
        <p class="text-brand-muted text-sm mt-1">
          Impartido por <span class="text-brand-primary font-semibold">Joel Josafat Hernandez Saucedo</span>
        </p>
      </div>
      <div class="flex items-center gap-3 text-sm text-brand-muted">
        <span>{nav.modules.length} módulo{nav.modules.length !== 1 ? 's' : ''}</span>
        <span class="w-1 h-1 rounded-full bg-brand-border"></span>
        <span>{nav.allLessonsOrdered.length} lecciones</span>
        {firstLesson && (
          <>
            <span class="w-1 h-1 rounded-full bg-brand-border"></span>
            <a
              href={`/${firstLesson.slug}`}
              class="inline-flex items-center gap-1.5 rounded-lg bg-brand-primary text-white px-4 py-2 font-semibold text-xs hover:bg-brand-accent transition-colors"
            >
              Comenzar
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </>
        )}
      </div>
    </div>

    <!-- Grid de contenido -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {allGroups.map((group) => {
        const isExtra = !/^\d/.test(group.title);
        const badgeNum = isExtra ? group.title.charAt(0) : (nav.modules.indexOf(group) + 1);
        const badgeClass = isExtra ? 'module-badge-m0' : `module-badge-m${Math.min(nav.modules.indexOf(group) + 1, 7)}`;
        const firstSlug = group.topics[0]?.lessons[0]?.slug || '#';
        const lessonCount = group.topics.reduce((s, t) => s + t.lessons.length, 0);

        return (
          <a
            href={`/${firstSlug}`}
            class={`card-hover flex items-center gap-4 rounded-xl border ${isExtra ? 'border-dashed border-brand-border' : 'border-brand-border'} bg-white dark:bg-brand-sidebar-bg p-4 ${isExtra ? '' : ''}`}
          >
            <span class={`module-badge ${badgeClass} shrink-0 text-xs font-bold`}>{badgeNum}</span>
            <div class="min-w-0 flex-1">
              <span class="block text-sm font-semibold text-brand-navy dark:text-white truncate">{group.title}</span>
              <span class="block text-xs text-brand-muted mt-0.5">
                {lessonCount} {lessonCount === 1 ? 'lección' : 'lecciones'}
              </span>
            </div>
            <svg class="h-4 w-4 text-brand-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
