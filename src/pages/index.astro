---
import { getCollection, render } from 'astro:content';
import { getNavigationStructure } from '../utils/navigation';
import Layout from '../layouts/Layout.astro';
import Dashboard from '../components/Dashboard.astro';

const lecciones = await getCollection('lecciones');
const nav = getNavigationStructure(lecciones);
const firstLesson = nav.allLessonsOrdered.length > 0 ? nav.allLessonsOrdered[0] : null;

const mensajes = await getCollection('mensajes');
const sortedMensajes = mensajes.sort((a, b) => b.data.fecha.localeCompare(a.data.fecha));
const latestMensaje = sortedMensajes.length > 0 ? sortedMensajes[0] : null;
const MensajeContent = latestMensaje ? (await render(latestMensaje)).Content : null;
---

<Layout title="Inicio">
  <div class="max-w-2xl mx-auto">
    <!-- Header compacto -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 pb-6 border-b border-brand-border">
      <div>
        <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-brand-navy dark:text-white tracking-tight">
          Plataforma de Estudios
        </h1>
        <p class="text-brand-muted text-sm mt-1">
          Impartido por <span class="text-brand-primary font-semibold">Joel Josafat Hernandez Saucedo</span>
        </p>
      </div>
      <div class="flex items-center gap-3 text-sm text-brand-muted">
        <span>{nav.modules.length} módulo{nav.modules.length !== 1 ? 's' : ''}</span>
        <span class="w-1 h-1 rounded-full bg-brand-border"></span>
        <span>{nav.allLessonsOrdered.length} lecciones</span>
        {firstLesson && (
          <>
            <span class="w-1 h-1 rounded-full bg-brand-border"></span>
            <a
              href={`/${firstLesson.slug}`}
              class="inline-flex items-center gap-1.5 rounded-lg bg-brand-primary text-white px-4 py-2 font-semibold text-xs hover:bg-brand-accent transition-colors"
            >
              Primera lección
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </>
        )}
      </div>
    </div>

    <!-- Mensaje semanal -->
    {latestMensaje && MensajeContent && (
      <div class="rounded-xl border border-brand-amber/20 bg-brand-amber-bg dark:bg-amber-950/20 p-4 mb-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm">📢</span>
          <span class="text-xs font-semibold uppercase tracking-wider text-brand-amber">
            {latestMensaje.data.title || 'Mensaje del profesor'}
          </span>
          <span class="text-xs text-brand-muted ml-auto">{latestMensaje.data.fecha}</span>
        </div>
        <div class="text-sm text-brand-text dark:text-brand-text leading-relaxed prose-sm">
          <MensajeContent />
        </div>
      </div>
    )}

    <!-- Dashboard con Alpine (client-side) -->
    <Dashboard nav={nav} />
  </div>
</Layout>
